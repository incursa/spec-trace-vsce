{
  "name": "spec-trace-vsce",
  "displayName": "Spec Trace",
  "description": "Browse Spec Trace artifacts and edit specification requirements in a dense custom editor.",
  "version": "1.0.7",
  "publisher": "incursa",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "vscode": "^1.110.0"
  },
  "preview": true,
  "pricing": "Free",
  "markdown": "github",
  "galleryBanner": {
    "color": "#35357A",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/incursa/spec-trace-vsce.git"
  },
  "homepage": "https://github.com/incursa/spec-trace-vsce",
  "bugs": {
    "url": "https://github.com/incursa/spec-trace-vsce/issues"
  },
  "categories": [
    "Other",
    "Testing"
  ],
  "keywords": [
    "requirements",
    "traceability",
    "specification",
    "verification",
    "architecture",
    "work-items",
    "spec-trace"
  ],
  "icon": "images/icon.png",
  "browser": "./dist/web/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "spec-trace-vsce.openSmokeFixture",
        "title": "Spec Trace: Open Smoke Fixture",
        "category": "Spec Trace"
      },
      {
        "command": "spec-trace-vsce.openRepositoryExplorer",
        "title": "Spec Trace: Open Repository Explorer",
        "category": "Spec Trace"
      },
      {
        "command": "spec-trace-vsce.refreshRepositoryExplorer",
        "title": "Spec Trace: Refresh Repository Explorer",
        "category": "Spec Trace"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specTraceExplorer",
          "title": "Spec Trace",
          "icon": "resources/spec-trace.svg"
        }
      ]
    },
    "views": {
      "specTraceExplorer": [
        {
          "id": "specTraceExplorer.navigator",
          "name": "Repository Explorer",
          "canCollapse": true
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "spec-trace-vsce.specFileEditor",
        "displayName": "Spec Trace Specification Editor",
        "selector": [
          {
            "filenamePattern": "**/specs/requirements/**/*.json"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "activationEvents": [
    "onCustomEditor:spec-trace-vsce.specFileEditor",
    "onView:specTraceExplorer.navigator",
    "onCommand:spec-trace-vsce.openRepositoryExplorer",
    "onCommand:spec-trace-vsce.refreshRepositoryExplorer"
  ],
  "scripts": {
    "test": "npm run test:web && npm run test:webview",
    "pretest": "npm run compile-web",
    "vscode:prepublish": "npm run package-web",
    "compile-web": "npm run check-types && npm run lint && node esbuild.js",
    "test:web": "vscode-test-web --browserType=chromium --headless --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/suite/extensionTests.js",
    "test:webview": "node scripts/webview-smoke.mjs",
    "watch-web": "npm-run-all -p watch-web:*",
    "watch-web:esbuild": "node esbuild.js --watch",
    "watch-web:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package-web": "npm run check-types && npm run lint && node esbuild.js --production",
    "release:check": "npm run package-web",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ."
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@incursa/ui-kit": "^1.7.0",
    "@types/assert": "^1.5.11",
    "@types/mocha": "^10.0.10",
    "@types/vscode": "^1.110.0",
    "@vscode/test-web": "^0.0.80",
    "assert": "^2.1.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
